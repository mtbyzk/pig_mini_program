/* app.wxss - 全局样式 */

/* 小红书风格主题变量 */
page {
  --primary-color: #FF2442;
  --primary-light: #FF6B81;
  --primary-dark: #E8364A;
  --bg-color: #F5F5F5;
  --card-color: #FFFFFF;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-light: #999999;
  --success-color: #2ED573;
  --warning-color: #FFA502;
  --danger-color: #FF4757;
  --info-color: #70A1FF;
  --border-color: #EEEEEE;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用样式 */
.container {
  padding: 24rpx;
}

.card {
  background-color: var(--card-color);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.section-header .title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(255, 36, 66, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background-color: rgba(46, 213, 115, 0.1);
  color: var(--success-color);
}

.tag-warning {
  background-color: rgba(255, 165, 2, 0.1);
  color: var(--warning-color);
}

.tag-danger {
  background-color: rgba(255, 71, 87, 0.1);
  color: var(--danger-color);
}

/* 诊断卡片 */
.diagnosis-card {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 24rpx;
  padding: 32rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.diagnosis-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
}

.diagnosis-card .tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.diagnosis-card .title {
  font-size: 48rpx;
  font-weight: 700;
  margin: 16rpx 0;
}

.diagnosis-card .subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 功能网格 */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-item {
  width: calc(50% - 10rpx);
  background-color: var(--card-color);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.feature-item .icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.feature-item .icon-wrapper .icon {
  width: 40rpx;
  height: 40rpx;
}

.feature-item .info .name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.feature-item .info .desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 疾病列表 */
.disease-item {
  background-color: var(--card-color);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.disease-item .icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.disease-item .content {
  flex: 1;
}

.disease-item .content .name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.disease-item .content .desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.disease-item .content .tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.disease-item .arrow {
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 24rpx;
  padding: 32rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
}

.user-card .avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.user-card .info {
  flex: 1;
}

.user-card .info .name {
  font-size: 36rpx;
  font-weight: 700;
}

.user-card .info .desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.user-card .badge {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 设置列表 */
.settings-group {
  background-color: var(--card-color);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item .icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 36, 66, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.settings-item .icon-wrapper .icon {
  width: 32rpx;
  height: 32rpx;
}

.settings-item .content {
  flex: 1;
}

.settings-item .content .name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.settings-item .content .value {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.settings-item .arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 开关样式 */
.switch {
  --switch-color: var(--primary-color);
}

/* 底部信息 */
.footer-info {
  text-align: center;
  padding: 40rpx 0;
}

.footer-info .logo {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  background-color: rgba(255, 36, 66, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-info .app-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.footer-info .developer {
  font-size: 24rpx;
  color: var(--primary-color);
  margin: 8rpx 0;
}

.footer-info .slogan {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.footer-info .disclaimer {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 16rpx;
}

/* 搜索框 */
.search-bar {
  background-color: var(--card-color);
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.search-bar .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-bar input::placeholder {
  color: var(--text-light);
}

/* 标签选择器 */
.tag-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 0;
}

.tag-selector .tag {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background-color: var(--card-color);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.tag-selector .tag.active {
  background-color: rgba(255, 36, 66, 0.1);
  color: var(--primary-color);
  border-color: var(--primary-color);
}

/* 症状选择 */
.symptom-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.symptom-item {
  padding: 16rpx 24rpx;
  background-color: var(--card-color);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.symptom-item.selected {
  background-color: rgba(255, 36, 66, 0.1);
  color: var(--primary-color);
  border-color: var(--primary-color);
}

/* 诊断结果 */
.result-item {
  background-color: var(--card-color);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.result-item .header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-item .header .name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.result-item .header .score {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: conic-gradient(var(--primary-color) var(--score-percent), #EEEEEE 0);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.result-item .header .score::before {
  content: '';
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: var(--card-color);
  position: absolute;
}

.result-item .header .score .value {
  position: relative;
  z-index: 1;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--primary-color);
}

/* 治疗方案 */
.treatment-plan {
  background-color: var(--card-color);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.treatment-plan .plan-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.treatment-plan .plan-header .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.treatment-plan .plan-header .title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 药品卡片 */
.medication-card {
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.medication-card .name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.medication-card .info-row {
  display: flex;
  margin-bottom: 8rpx;
}

.medication-card .info-row .label {
  width: 80rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.medication-card .info-row .value {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 注意事项 */
.notes-card {
  background-color: rgba(255, 165, 2, 0.05);
  border: 2rpx solid rgba(255, 165, 2, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.notes-card .header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.notes-card .header .icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.notes-card .header .title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--warning-color);
}

.notes-card .content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 护理建议 */
.nursing-card {
  background-color: rgba(112, 161, 255, 0.05);
  border: 2rpx solid rgba(112, 161, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.nursing-card .header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nursing-card .header .icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.nursing-card .header .title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--info-color);
}

.nursing-card .content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-state .icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  opacity: 0.3;
}

.empty-state .text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading .spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading .text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

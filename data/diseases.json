[
  {"id": "d01", "name": "猪瘟", "alias": "烂肠瘟", "description": "猪瘟是由猪瘟病毒引起的一种急性、热性、高度接触性传染病。特征为高热稽留、小肠坏死、全身广泛性出血。", "severity": "high", "is_contagious": true, "incubation_period": "5-7天", "mortality_rate": "急性型可达90%以上", "images": [], "videos": [], "characteristic_symptoms": ["高热稽留不退，体温持续41℃以上", "先便秘后腹泻，粪便恶臭", "皮肤有出血点，尤以耳根、腹部、四肢内侧明显", "眼结膜有脓性分泌物"], "prevention": "定期接种猪瘟疫苗，加强饲养管理，严格检疫制度。"},

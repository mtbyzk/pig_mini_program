/* pages/diagnosis-result/diagnosis-result.wxss */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 诊断摘要 */
.summary-card {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.summary-card .summary-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.summary-card .summary-icon-text {
  font-size: 32rpx;
}

.summary-card .summary-info {
  flex: 1;
}

.summary-card .summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.summary-card .summary-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 结果列表 */
.result-list {
  margin-bottom: 24rpx;
}

.result-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  align-items: center;
}

.result-header .result-info {
  flex: 1;
}

.result-header .result-info .result-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.result-header .result-info .result-alias {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 匹配度显示 */
.match-percent {
  text-align: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  border-radius: 16rpx;
}

.match-percent .percent-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.match-percent .percent-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.result-divider {
  height: 2rpx;
  background-color: #F5F5F5;
  margin: 16rpx 0;
}

.result-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(255, 36, 66, 0.1);
  color: #FF2442;
}

.tag-success {
  background-color: rgba(46, 213, 115, 0.1);
  color: #2ED573;
}

.tag-warning {
  background-color: rgba(255, 165, 2, 0.1);
  color: #FFA502;
}

.tag-danger {
  background-color: rgba(255, 71, 87, 0.1);
  color: #FF4757;
}

.matched-symptoms {
  margin-bottom: 16rpx;
}

.matched-symptoms .symptoms-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 12rpx;
}

.matched-symptoms .symptoms-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.matched-symptoms .symptoms-list .symptom-tag {
  padding: 8rpx 16rpx;
  background-color: rgba(255, 36, 66, 0.08);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #FF2442;
}

.view-detail {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.view-detail text {
  font-size: 26rpx;
  color: #FF2442;
  font-weight: 500;
}

.view-detail .arrow-text {
  font-size: 32rpx;
  color: #FF2442;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-state .empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-state .sub-text {
  font-size: 24rpx;
  color: #CCCCCC;
  margin-bottom: 32rpx;
}

.empty-state .btn-retry {
  display: inline-block;
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  color: #FFFFFF;
  padding: 16rpx 48rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

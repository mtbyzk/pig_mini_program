<!-- pages/diagnosis-result/diagnosis-result.wxml -->
<view class="container">
  <!-- 诊断摘要 -->
  <view class="summary-card">
    <view class="summary-icon">
      <text class="summary-icon-text">📊</text>
    </view>
    <view class="summary-info">
      <view class="summary-title">分析完成</view>
      <view class="summary-desc">已选择 {{symptomCount}} 个症状，匹配到 {{results.length}} 种可能疾病</view>
    </view>
  </view>

  <!-- 诊断结果列表 -->
  <view class="result-list" wx:if="{{results.length > 0}}">
    <view class="result-item" wx:for="{{results}}" wx:key="diseaseId" bindtap="goToTreatment" data-id="{{item.diseaseId}}">
      <view class="result-header">
        <view class="result-info">
          <view class="result-name">{{item.diseaseName}}</view>
          <view class="result-alias" wx:if="{{item.alias}}">别名: {{item.alias}}</view>
        </view>
        <view class="match-percent">
          <text class="percent-value">{{item.matchPercentage}}</text>
          <text class="percent-label">匹配度</text>
        </view>
      </view>

      <view class="result-divider"></view>

      <view class="result-tags">
        <view class="tag {{item.severity === 'high' ? 'tag-danger' : item.severity === 'medium' ? 'tag-warning' : 'tag-success'}}">
          {{item.severityText}}
        </view>
        <view class="tag tag-primary" wx:if="{{item.isContagious}}">传染性</view>
      </view>

      <view class="matched-symptoms">
        <view class="symptoms-title">匹配症状 ({{item.matchedSymptoms}}/{{item.totalSymptoms}})</view>
        <view class="symptoms-list">
          <view class="symptom-tag" wx:for="{{item.matchedSymptomNames}}" wx:for-item="symptom" wx:key="*this">
            {{symptom}}
          </view>
        </view>
      </view>

      <view class="view-detail">
        <text>查看治疗方案</text>
        <text class="arrow-text">›</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">🔍</text>
    <view class="text">未找到匹配的疾病</view>
    <view class="sub-text">请尝试选择更多症状或重新分析</view>
    <view class="btn-retry" bindtap="retryDiagnosis">重新分析</view>
  </view>
</view>

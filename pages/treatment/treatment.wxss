/* pages/treatment/treatment.wxss */

.container {
  padding: 24rpx;
}

/* 疾病头部 */
.disease-header {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.disease-header .header-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.disease-header .header-icon-text {
  font-size: 40rpx;
}

.disease-header .header-info .header-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.disease-header .header-info .header-severity {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 典型症状 */
.symptoms-section {
  margin-bottom: 24rpx;
}

.symptoms-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.symptoms-card .symptom-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.symptoms-card .symptom-item:last-child {
  margin-bottom: 0;
}

.symptoms-card .symptom-item .symptom-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #FF2442;
  margin-top: 10rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.symptoms-card .symptom-item .symptom-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 方案选择器 */
.plan-selector {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.plan-selector .selector-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.plan-selector .selector-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.plan-selector .selector-header .title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
}

.plan-scroll {
  white-space: nowrap;
}

.plan-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.plan-tab {
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666666;
  white-space: nowrap;
}

.plan-tab.active {
  background-color: rgba(255, 36, 66, 0.1);
  color: #FF2442;
}

/* 区块样式 */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-header .section-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.section-header .section-icon-wrapper.injection {
  background-color: rgba(255, 36, 66, 0.1);
}

.section-header .section-icon-wrapper.oral {
  background-color: rgba(46, 213, 115, 0.1);
}

.section-header .section-icon-wrapper.topical {
  background-color: rgba(255, 165, 2, 0.1);
}

.section-header .section-icon-wrapper.notes {
  background-color: rgba(255, 165, 2, 0.1);
}

.section-header .section-icon-wrapper.nursing {
  background-color: rgba(112, 161, 255, 0.1);
}

.section-header .section-icon-text {
  font-size: 28rpx;
}

.section-header .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* 药品卡片 */
.medication-card {
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.medication-card .medication-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.medication-card .info-row {
  display: flex;
  margin-bottom: 8rpx;
}

.medication-card .info-row .label {
  width: 80rpx;
  font-size: 24rpx;
  color: #666666;
}

.medication-card .info-row .value {
  flex: 1;
  font-size: 24rpx;
  color: #1A1A1A;
}

/* 注意事项卡片 */
.notes-card {
  background-color: rgba(255, 165, 2, 0.05);
  border: 2rpx solid rgba(255, 165, 2, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.notes-card .notes-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 护理建议卡片 */
.nursing-card {
  background-color: rgba(112, 161, 255, 0.05);
  border: 2rpx solid rgba(112, 161, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.nursing-card .nursing-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

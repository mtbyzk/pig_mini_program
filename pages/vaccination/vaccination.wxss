/* pages/vaccination/vaccination.wxss */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 提示卡片 */
.tip-card {
  background: linear-gradient(135deg, #5AC8FA, #007AFF);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.tip-card .tip-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.tip-card .tip-icon-text {
  font-size: 36rpx;
}

.tip-card .tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #FFFFFF;
  line-height: 1.5;
}

/* 阶段选择 */
.stage-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.stage-selector {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.stage-tag {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background-color: #FFFFFF;
  color: #666666;
  border: 2rpx solid #EEEEEE;
  white-space: nowrap;
}

.stage-tag.active {
  background-color: #FF2442;
  color: #FFFFFF;
  border-color: #FF2442;
}

/* 疫苗列表 */
.vaccine-list {
  margin-bottom: 24rpx;
}

.vaccine-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.vaccine-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.vaccine-name {
  display: flex;
  align-items: center;
  flex: 1;
}

.vaccine-name .name-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-right: 12rpx;
}

.importance-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.importance-tag.high {
  background-color: rgba(255, 71, 87, 0.1);
  color: #FF4757;
}

.importance-tag.medium {
  background-color: rgba(255, 165, 2, 0.1);
  color: #FFA502;
}

.stage-badge {
  padding: 6rpx 16rpx;
  background-color: rgba(0, 122, 255, 0.1);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #007AFF;
  font-weight: 500;
}

/* 疫苗信息 */
.vaccine-info {
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 16rpx;
}

.info-row {
  display: flex;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .info-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #666666;
}

.info-row .info-value {
  flex: 1;
  font-size: 24rpx;
  color: #1A1A1A;
}

.info-row .info-value.notes {
  color: #FF2442;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-state .empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999999;
}

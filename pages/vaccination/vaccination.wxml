<!-- pages/vaccination/vaccination.wxml -->
<view class="container">
  <!-- 顶部提示 -->
  <view class="tip-card">
    <view class="tip-icon">
      <text class="tip-icon-text">💉</text>
    </view>
    <view class="tip-text">科学免疫，预防为主。以下为各类型猪只推荐免疫程序。</view>
  </view>

  <!-- 猪只类型选择 -->
  <view class="type-selector">
    <view 
      wx:for="{{pigTypes}}" 
      wx:key="key"
      class="type-tag {{selectedType === item.key ? 'active' : ''}}" 
      bindtap="selectType" 
      data-type="{{item.key}}"
    >
      <text class="type-icon">{{item.key === 'all' ? '📋' : item.key === 'fattening' ? '🐷' : item.key === 'sow' ? '🐷' : '🐗'}}</text>
      <text class="type-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 疫苗列表 -->
  <view class="vaccine-list">
    <view class="vaccine-item" wx:for="{{filteredVaccines}}" wx:key="id">
      <view class="vaccine-header">
        <view class="vaccine-name">
          <text class="name-text">{{item.name}}</text>
          <view class="importance-tag {{item.importance === 'high' ? 'high' : 'medium'}}">
            {{item.importance === 'high' ? '必做' : '推荐'}}
          </view>
        </view>
        <view class="type-badge">{{item.typeName}}</view>
      </view>
      
      <view class="vaccine-info">
        <view class="info-row">
          <text class="info-label">接种时间</text>
          <text class="info-value">{{item.time}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">剂量</text>
          <text class="info-value">{{item.dosage}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">接种方式</text>
          <text class="info-value">{{item.route}}</text>
        </view>
        <view class="info-row" wx:if="{{item.notes}}">
          <text class="info-label">备注</text>
          <text class="info-value notes">{{item.notes}}</text>
        </view>
      </view>

      <!-- 特殊注意事项 -->
      <view class="special-notes" wx:if="{{item.special_notes && item.special_notes.length > 0}}">
        <view class="notes-header">
          <text class="notes-icon">⚠️</text>
          <text class="notes-title">特殊注意事项</text>
        </view>
        <view class="notes-content">
          <view class="note-item" wx:for="{{item.special_notes}}" wx:for-item="note" wx:key="*this">
            <text class="note-text {{note === '' ? 'empty' : ''}}">{{note || ' '}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredVaccines.length === 0}}">
    <text class="empty-icon">💉</text>
    <view class="text">暂无该类型疫苗信息</view>
  </view>
</view>

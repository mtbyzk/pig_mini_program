<!-- pages/encyclopedia/encyclopedia.wxml -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <image class="icon" src="/images/search.png" mode="aspectFit"></image>
    <input 
      placeholder="搜索疾病名称或症状..." 
      value="{{searchQuery}}" 
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="tag-scroll">
    <view class="tag-selector">
      <view 
        class="tag {{selectedCategory === 'all' ? 'active' : ''}}" 
        bindtap="selectCategory" 
        data-category="all"
      >全部</view>
      <view 
        class="tag {{selectedCategory === 'high' ? 'active' : ''}}" 
        bindtap="selectCategory" 
        data-category="high"
      >高危</view>
      <view 
        class="tag {{selectedCategory === 'contagious' ? 'active' : ''}}" 
        bindtap="selectCategory" 
        data-category="contagious"
      >传染性</view>
      <view 
        class="tag {{selectedCategory === 'digestive' ? 'active' : ''}}" 
        bindtap="selectCategory" 
        data-category="digestive"
      >消化道</view>
      <view 
        class="tag {{selectedCategory === 'respiratory' ? 'active' : ''}}" 
        bindtap="selectCategory" 
        data-category="respiratory"
      >呼吸道</view>
      <view 
        class="tag {{selectedCategory === 'skin' ? 'active' : ''}}" 
        bindtap="selectCategory" 
        data-category="skin"
      >皮肤</view>
    </view>
  </scroll-view>

  <!-- 疾病列表 -->
  <view class="disease-list" wx:if="{{filteredDiseases.length > 0}}">
    <view 
      class="disease-item" 
      wx:for="{{filteredDiseases}}" 
      wx:key="id" 
      bindtap="goToDiseaseDetail" 
      data-id="{{item.id}}"
    >
      <view class="icon-wrapper" style="background-color: {{item.severity === 'high' ? 'rgba(255, 71, 87, 0.1)' : item.severity === 'medium' ? 'rgba(255, 165, 2, 0.1)' : 'rgba(46, 213, 115, 0.1)'}};">
        <image class="icon" src="/images/warning.png" mode="aspectFit"></image>
      </view>
      <view class="content">
        <view class="name">{{item.name}}</view>
        <view class="desc">{{item.description}}</view>
        <view class="tags">
          <view class="tag {{item.severity === 'high' ? 'tag-danger' : item.severity === 'medium' ? 'tag-warning' : 'tag-success'}}">
            {{item.severity === 'high' ? '高危' : item.severity === 'medium' ? '中危' : '低危'}}
          </view>
          <view class="tag tag-primary" wx:if="{{item.is_contagious}}">传染性</view>
        </view>
      </view>
      <image class="arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <image class="icon" src="/images/search-off.png" mode="aspectFit"></image>
    <view class="text">未找到相关疾病</view>
  </view>
</view>

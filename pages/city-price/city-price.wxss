/* pages/city-price/city-price.wxss */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 顶部信息 */
.header-card {
  background: linear-gradient(135deg, #FF6B81, #FF2442);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 48rpx;
}

/* 省份选择器 */
.province-selector {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.selector-content {
  display: flex;
  align-items: center;
}

.selector-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.selector-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.selector-arrow {
  font-size: 24rpx;
  color: #999999;
}

/* 省份选择弹窗 */
.province-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: relative;
  background-color: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  max-height: 70vh;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.picker-close {
  font-size: 32rpx;
  color: #999999;
  padding: 8rpx;
}

.picker-list {
  max-height: 60vh;
  padding: 16rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.picker-item.active {
  background-color: rgba(255, 36, 66, 0.05);
}

.picker-item text {
  font-size: 28rpx;
  color: #1A1A1A;
}

.picker-item.active text {
  color: #FF2442;
  font-weight: 600;
}

.picker-item .check {
  color: #FF2442;
  font-size: 28rpx;
  font-weight: 700;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #EEEEEE;
  border-top-color: #FF2442;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 城市列表 */
.city-list {
  margin-bottom: 24rpx;
}

.list-header {
  background-color: #F8F9FA;
  border-radius: 16rpx 16rpx 0 0;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
}

.list-header text {
  font-size: 24rpx;
  font-weight: 600;
  color: #666666;
}

.header-city {
  flex: 1;
}

.header-price {
  width: 120rpx;
  text-align: center;
}

.header-kg {
  width: 140rpx;
  text-align: center;
}

.header-trend {
  width: 80rpx;
  text-align: right;
}

.city-item {
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F5F5F5;
}

.city-item:last-child {
  border-radius: 0 0 16rpx 16rpx;
}

.city-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.city-price {
  width: 120rpx;
  text-align: center;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF2442;
}

.city-kg {
  width: 140rpx;
  text-align: center;
}

.kg-value {
  font-size: 26rpx;
  color: #666666;
}

.trend {
  width: 80rpx;
  text-align: right;
}

.trend.up {
  color: #FF4757;
}

.trend.down {
  color: #2ED573;
}

.trend.stable {
  color: #999999;
}

.trend-icon {
  font-size: 24rpx;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-state .empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999999;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 24rpx 0;
}

.footer-tip text {
  font-size: 22rpx;
  color: #999999;
}

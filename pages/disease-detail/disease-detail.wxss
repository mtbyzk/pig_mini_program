/* pages/disease-detail/disease-detail.wxss */

.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* 疾病头部 */
.disease-header {
  margin-bottom: 24rpx;
}

.disease-header .header-bg {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  border-radius: 24rpx;
  padding: 32rpx;
}

.disease-header .header-content .disease-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.disease-header .header-content .disease-alias {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.disease-header .header-content .disease-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.tag-success {
  background-color: rgba(46, 213, 115, 0.2);
  color: #FFFFFF;
}

.tag-warning {
  background-color: rgba(255, 165, 2, 0.2);
  color: #FFFFFF;
}

.tag-danger {
  background-color: rgba(255, 71, 87, 0.2);
  color: #FFFFFF;
}

/* 区块样式 */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-header .section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-header .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* 描述卡片 */
.description-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.description-card .description-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 症状卡片 */
.symptoms-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.symptoms-card .symptom-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.symptoms-card .symptom-item:last-child {
  margin-bottom: 0;
}

.symptoms-card .symptom-item .symptom-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #FF2442;
  margin-top: 10rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.symptoms-card .symptom-item .symptom-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 疾病分型 */
.types-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.types-card .type-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.types-card .type-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.types-card .type-header {
  margin-bottom: 12rpx;
}

.types-card .type-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF2442;
}

.types-card .type-symptoms {
  padding-left: 16rpx;
}

.types-card .type-symptom {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.types-card .type-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #999999;
  margin-top: 10rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.types-card .type-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

/* 鉴别要点 */
.differential-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.differential-card .differential-item {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.differential-card .differential-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.differential-card .differential-header {
  margin-bottom: 8rpx;
}

.differential-card .differential-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.differential-card .differential-content {
  padding-left: 16rpx;
}

.differential-card .differential-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* 信息卡片 */
.info-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.info-card .info-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.info-card .info-row:last-child {
  border-bottom: none;
}

.info-card .info-row .info-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666666;
}

.info-card .info-row .info-value {
  flex: 1;
  font-size: 26rpx;
  color: #1A1A1A;
}

/* 预防卡片 */
.prevention-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.prevention-card .prevention-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.bottom-bar .btn-treatment {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  color: #FFFFFF;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

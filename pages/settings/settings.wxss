/* pages/settings/settings.wxss */

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  border-radius: 24rpx;
  padding: 32rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-card .avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.user-card .avatar .avatar-icon {
  font-size: 48rpx;
}

.user-card .info {
  flex: 1;
}

.user-card .info .name {
  font-size: 36rpx;
  font-weight: 700;
}

.user-card .info .desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.user-card .badge {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  margin-top: 16rpx;
}

.section-header .title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
}

/* 设置列表 */
.settings-group {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item .icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 36, 66, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.settings-item .item-icon {
  font-size: 32rpx;
}

.settings-item .content {
  flex: 1;
}

.settings-item .content .name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.settings-item .content .value {
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
}

.settings-item .arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 底部信息 */
.footer-info {
  text-align: center;
  padding: 40rpx 0;
}

.footer-info .logo {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  background-color: rgba(255, 36, 66, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-info .logo .logo-icon {
  font-size: 48rpx;
}

.footer-info .app-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.footer-info .developer {
  font-size: 24rpx;
  color: #FF2442;
  margin: 8rpx 0;
}

.footer-info .slogan {
  font-size: 24rpx;
  color: #666666;
}

.footer-info .disclaimer {
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
}

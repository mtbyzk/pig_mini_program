/* pages/privacy/privacy.wxss */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.header .title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header .update-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.section-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.section-content .item {
  margin-bottom: 12rpx;
}

.section-content .item:last-child {
  margin-bottom: 0;
}

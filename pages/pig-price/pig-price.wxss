/* pages/pig-price/pig-price.wxss */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 顶部信息 */
.header-card {
  background: linear-gradient(135deg, #FF6B81, #FF2442);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.header-update {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 48rpx;
}

/* 品种选择 */
.type-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.type-tag {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #EEEEEE;
}

.type-tag.active {
  background-color: #FF2442;
  border-color: #FF2442;
}

.type-tag .type-name {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}

.type-tag.active .type-name {
  color: #FFFFFF;
}

.type-tag .type-price {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #FF2442;
}

.type-tag.active .type-price {
  color: #FFFFFF;
}

/* 价格统计 */
.stats-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.stat-value.avg {
  color: #FF2442;
}

.stat-value.max {
  color: #FF4757;
}

.stat-value.min {
  color: #2ED573;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #EEEEEE;
}

/* 饲料信息 */
.feed-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.feed-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.feed-items {
  display: flex;
  justify-content: space-around;
}

.feed-item {
  text-align: center;
}

.feed-name {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.feed-price {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.feed-price.ratio {
  color: #FF2442;
}

.feed-change {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.feed-change.up {
  color: #FF4757;
}

.feed-change.down {
  color: #2ED573;
}

/* 排序按钮 */
.sort-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.sort-btn {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.sort-btn.active {
  background-color: #FF2442;
  color: #FFFFFF;
}

.sort-icon {
  font-size: 20rpx;
}

/* 价格列表 */
.price-list {
  margin-bottom: 24rpx;
}

.price-header {
  background-color: #F8F9FA;
  border-radius: 16rpx 16rpx 0 0;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
}

.price-header text {
  font-size: 24rpx;
  font-weight: 600;
  color: #666666;
}

.header-province {
  width: 120rpx;
}

.header-price {
  flex: 1;
  text-align: center;
}

.header-kg {
  width: 140rpx;
  text-align: center;
}

.header-trend {
  width: 120rpx;
  text-align: right;
}

.price-item {
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F5F5F5;
}

.price-item:last-child {
  border-radius: 0 0 16rpx 16rpx;
}

.province-name {
  width: 120rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.price-value {
  flex: 1;
  text-align: center;
}

.price-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF2442;
}

.price-kg {
  width: 140rpx;
  text-align: center;
}

.kg-num {
  font-size: 26rpx;
  color: #666666;
}

.trend {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4rpx;
}

.trend.up {
  color: #FF4757;
}

.trend.down {
  color: #2ED573;
}

.trend.stable {
  color: #999999;
}

.trend-icon {
  font-size: 24rpx;
  font-weight: 600;
}

.trend-change {
  font-size: 22rpx;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 24rpx 0;
}

.footer-tip text {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 顶部开发者信息 -->
  <view class="developer-info">
    <text class="developer-text">开发者：WangXin</text>
  </view>

  <!-- 诊断卡片 -->
  <view class="diagnosis-card" bindtap="goToDiagnosis">
    <view class="tag">AI 智能诊断</view>
    <view class="title">开始诊断</view>
    <view class="subtitle">选择症状，快速判断疾病\n获取专业用药方案</view>
    <view class="icon-circle">
      <image class="icon" src="/images/medical.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 功能网格 -->
  <view class="section-header">
    <image class="icon" src="/images/grid.png" mode="aspectFit"></image>
    <text class="title">快速入口</text>
  </view>
  <view class="feature-grid">
    <view class="feature-item" bindtap="goToDiagnosis">
      <view class="icon-wrapper" style="background-color: rgba(255, 107, 129, 0.1);">
        <image class="icon" src="/images/biotech.png" mode="aspectFit"></image>
      </view>
      <view class="info">
        <view class="name">疾病诊断</view>
        <view class="desc">根据症状诊断</view>
      </view>
    </view>
    <view class="feature-item" bindtap="goToDiagnosis">
      <view class="icon-wrapper" style="background-color: rgba(255, 71, 87, 0.1);">
        <image class="icon" src="/images/vaccines.png" mode="aspectFit"></image>
      </view>
      <view class="info">
        <view class="name">用药方案</view>
        <view class="desc">联合用药指导</view>
      </view>
    </view>
    <view class="feature-item" bindtap="goToEncyclopedia">
      <view class="icon-wrapper" style="background-color: rgba(255, 36, 66, 0.1);">
        <image class="icon" src="/images/science.png" mode="aspectFit"></image>
      </view>
      <view class="info">
        <view class="name">药物配伍</view>
        <view class="desc">禁忌与注意事项</view>
      </view>
    </view>
    <view class="feature-item" bindtap="goToEncyclopedia">
      <view class="icon-wrapper" style="background-color: rgba(232, 70, 147, 0.1);">
        <image class="icon" src="/images/analytics.png" mode="aspectFit"></image>
      </view>
      <view class="info">
        <view class="name">诊断记录</view>
        <view class="desc">历史诊断查看</view>
      </view>
    </view>
  </view>

  <!-- 常见疾病 -->
  <view class="section-header">
    <image class="icon" src="/images/hospital.png" mode="aspectFit"></image>
    <text class="title">常见高危疾病</text>
    <view class="more" bindtap="goToEncyclopedia">查看全部</view>
  </view>
  <view class="disease-list">
    <view class="disease-item" wx:for="{{highSeverityDiseases}}" wx:key="id" bindtap="goToDiseaseDetail" data-id="{{item.id}}">
      <view class="icon-wrapper" style="background-color: rgba(255, 71, 87, 0.1);">
        <image class="icon" src="/images/warning.png" mode="aspectFit"></image>
      </view>
      <view class="content">
        <view class="name">{{item.name}}</view>
        <view class="desc">{{item.is_contagious ? '传染性 · ' : ''}}{{item.severity === 'high' ? '高危' : item.severity === 'medium' ? '中危' : '低危'}}</view>
        <view class="tags">
          <view class="tag tag-danger" wx:if="{{item.severity === 'high'}}">高危</view>
          <view class="tag tag-warning" wx:elif="{{item.severity === 'medium'}}">中危</view>
          <view class="tag tag-success" wx:else>低危</view>
          <view class="tag tag-primary" wx:if="{{item.is_contagious}}">传染性</view>
        </view>
      </view>
      <image class="arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-value">{{diseases.length}}</view>
      <view class="stat-label">疾病种类</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{symptoms.length}}</view>
      <view class="stat-label">症状数量</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{medications.length}}</view>
      <view class="stat-label">药品数量</view>
    </view>
  </view>
</view>
